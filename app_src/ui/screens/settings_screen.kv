#:import TEXT_COLOR_PRIMARY_LIGHT utils.constants.TEXT_COLOR_PRIMARY_LIGHT
#:import TEXT_COLOR_PRIMARY_DARK utils.constants.TEXT_COLOR_PRIMARY_DARK
#:import BUTTON_BG_DARK utils.constants.BUTTON_BG_DARK
#:import VERSION utils.constants.VERSION
#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import add_home_screen_widget utils.android.add_home_screen_widget
#:import toInt utils.helper.toInt




<MyMDButton@MDButton>:
    theme_bg_color:"Custom"
#    md_bg_color: TEXT_COLOR_PRIMARY_DARK if app.device_theme == "light" else  TEXT_COLOR_PRIMARY_LIGHT

    md_bg_color: TEXT_COLOR_PRIMARY_DARK if app.device_theme == "light" else BUTTON_BG_DARK
#    md_bg_color: get_color_from_hex("#262C3A")
#    text_color: get_color_from_hex("#98F1DD")

<CarouselTools@Column>:
    spacing: dp(15)
    size_hint_y: None
    height: self.minimum_height

    MDBoxLayout:
        spacing: dp(10)
        size_hint_x:1
        adaptive_size:True
        pos_hint: {"center_x": 0.5}
        MyMDButton:
            radius: [5]
            theme_bg_color:"Custom"
            on_release: app.sm.get_screen("settings").restart_service()

            MDButtonText:
                text: "Restart Carousel"
                size_hint_y: None
                theme_text_color:"Custom"
                height: dp(50)
                text_color: "black" if app.device_theme == "light" else "white"
        MyMDButton:
            theme_bg_color:"Custom"
            md_bg_color: TEXT_COLOR_PRIMARY_DARK if app.device_theme == "light" else BUTTON_BG_DARK
            radius: [5]
            pos_hint: {"center_x": 0.5}
            on_release:app.sm.get_screen("settings").terminate_carousel()
#            MDButtonIcon:
#                id: btn_icon
#                icon:"stop"
#                text_color: [1,.2,.2,1] #get_color_from_hex("#FF313")
            MDButtonText:
                id: btn_text
                text:  "Stop Carousel"
                theme_text_color:"Custom"
                text_color: "black" if app.device_theme == "light" else "white"



<SettingsScreen>:
    name: "settings"
    md_bg_color: [0.9, 0.9, 0.9, 1] if app.device_theme == "light" else [.1,.1,.1,1]
#    md_bg_color: [0.9, 0.9, 0.9, 1] if app.device_theme == "light" else get_color_from_hex("#1A1B1B")
    Column:
#        spacing: dp(25)
        pos_hint: {"top":1}
        MDBoxLayout:
            padding: dp(25), dp(20), dp(0), dp(25)
            size_hint_y: None
            height: self.minimum_height
            md_bg_color: [0.45,0.45,0.45, 1] if app.device_theme == "light" else [0.23,0.23,0.23, 1]
            MDLabel:
                text: "Settings"
                theme_text_color:"Custom"
                bold: True
                color: TEXT_COLOR_PRIMARY_LIGHT if app.device_theme == "light" else TEXT_COLOR_PRIMARY_DARK
                adaptive_size: True
                theme_font_size:"Custom"
                font_name: "RobotoMono"
                font_size:"22sp"
        ScrollView:
            size_hint: 1, 1
            Column:
                id: main_container
#                spacing: dp(25)
                size_hint_y: None
                height: self.minimum_height
#                md_bg_color:[1,0,1,1]
                padding: dp(25), dp(25), dp(25), dp(100)
                spacing: dp(15)
                MDLabel:
                    text: "Wallpaper Change Interval (minutes)"
                    size_hint_y: None
                    height: dp(30)
                    font_name: "RobotoMono"
                    font_size: sp(13)
                    color: TEXT_COLOR_PRIMARY_LIGHT if app.device_theme == "light" else TEXT_COLOR_PRIMARY_DARK

                Row:
                    spacing: dp(10)
                    size_hint_y: None
                    height: dp(50)
                    BorderInput:
                        id: interval_input_con
                        padding:[dp(2)]
                        size_hint_y:1
                        text: root.interval
                        pos_hint: {"center_y":.5}
#                        disabled:1
                        TextInput:
                            id: interval_input
                            text:root.interval
                            multiline: False
                            background_color:[0,0,0,0]
                            foreground_color: (1,1,1,1) if self.focus else [.8, .8, .8, 1]
                            padding_y: (self.height - self.line_height) / 2
                            input_filter:"float"
                            disabled_foreground_color: interval_input_con.disabled_color
#                    TextInput:
#                        text: root.interval
#                        text: "Set to 2.0mins"
#                        text_field_opacity_value_disabled_helper_text_label: [0,0,1,1]
#                        disabled_foreground_color:[0,0,1,1]
#                        hint_text: "mins"
#                        size_hint_x: 0.55
#                        theme_text_color:"Custom"
#                        text_color_focus: [0,0,0,1] if app.device_theme == "light" else [1, 1, 1, 1]
#                        text_color_normal: [.3,.3,.3,1] if app.device_theme == "light" else [.8, .8, .8, 1]
#                        theme_line_color: "Custom"
#                        line_color_focus: get_color_from_hex("#98F1DD")
#                        input_filter: "float"
#                        size_hint_y: 1
#                        radius: dp(20)

#                        halign:"left"
#                        foreground_color:[1,1,1,1]
#                        cursor_color:"blue"
#                        padding_y: (self.height - self.line_height) / 2
##                        disabled_foreground_color: (0,1,0, 1)
#                        input_filter: "float"
#                        background_color:[0,0,0,0]
#                        disabled:1

                    MDButton:
                        radius: [5]
                        radius: 20
                        theme_bg_color:"Custom"
                        size_hint_x: 0.35
                        theme_height: "Custom"
                        size_hint_y: .9
                        pos_hint:{"center_y":.5}
                        on_release: root.save_interval()
                        md_bg_color:get_color_from_hex("#98F1DD")

                        MDButtonText:
                            text: "Save"
                            size_hint_y: None
                            theme_text_color:"Custom"
                            height: dp(50)
                            text_color: get_color_from_hex("#262C3A")
#                            text_color: get_color_from_hex("#98F1DD")#"black" if app.device_theme == "light" else "white"
#                            text_color: "black" if app.device_theme == "light" else "white"
                            font_name: "RobotoMono"
                MDLabel:
                    id: interval_label
                    text: f"Using: {root.interval} mins"
                    size_hint_y: None
                    height: dp(30)
                    font_name: "RobotoMono"
                    color: TEXT_COLOR_PRIMARY_LIGHT if app.device_theme == "light" else TEXT_COLOR_PRIMARY_DARK

                MDGridLayout:
                    id:QuickSetButtonsBox
                    cols:3
                    adaptive_size: True
                    spacing:dp(10)
                    pos_hint:{"center_x":.5}

                    QuickSetButton:
                        text: "01:00"
                    QuickSetButton:
                        text: "05:00"
                    QuickSetButton:
                        text: "15:00"
                    QuickSetButton:
                        disabled:True
                        opacity:0
                    QuickSetButton:
                        text: "60:00"
#

                Column:
                    adaptive_height: True
                    padding: [dp(10),0,dp(10),0]
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(50)
    #                    md_bg_color: [0.75,0.75,0.75, 1]
                        md_bg_color: [0.45,0.45,0.45, 1] if app.device_theme == "light" else [0.23,0.23,0.23, 1]
                        radius: [dp(10),dp(10),dp(0),0]
                        adaptive_width:True
                        padding: [dp(10),0,dp(10),0]

                        MDLabel:
                            text:"Home Screen Widget"
                            theme_font_size:"Custom"
                            font_size: sp(14)
                            pos_hint: {"center_y": 0.5}
                            adaptive_size:True
                            color:"white"
                    Column:
                        md_bg_color:[.2,.2,.2,.3]
                        adaptive_size:True
                        size_hint_x:1
                        spacing:dp(10)
                        padding:[dp(10)]
                        radius:[0,dp(10),dp(10),dp(10)]
                        MDLabel:
                            id: countdown_label
                            text:"--:--"
                            pos_hint:{"right":1}
                            adaptive_size: True
                            theme_text_color: 'Custom'
                            text_color: "black" if app.device_theme == "light" else "white"
                            theme_font_name: "Custom"
                            font_name:"Roboto"
                            bold:True
                        Row:
                            adaptive_height:True
                            size_hint_x:1
                            spacing:dp(10)
                            Column:
                                adaptive_size: True
                                spacing:dp(5)
                                MDLabel:
                                    text:"Current"
                                    adaptive_size: True
                                    theme_font_name: "Custom"
                                    font_name:"Roboto"
                                    bold:True
                                    theme_font_size: 'Custom'
                                    font_size: sp(14)
                                    theme_text_color: 'Custom'
                                    text_color: get_color_from_hex("#98F1DD")
                                    padding: [dp(5),dp(2)]
                                    radius: [dp(5)]
                                    md_bg_color: get_color_from_hex("#262C3A")
                                FitImage:
                                    source:root.current_image_source
                                    radius:[10]
                                    fit_mode:"cover"
                                    size_hint:[None,None]
                                    size:[dp(120), dp(120)]
                            Column:
                                adaptive_size: True
                                spacing:dp(5)
                                MDLabel:
                                    text:"Next"
                                    adaptive_size: True
                                    theme_font_name: "Custom"
                                    font_name:"Roboto"
                                    bold:True
                                    theme_font_size: 'Custom'
                                    font_size: sp(14)
                                    theme_text_color: 'Custom'
                                    text_color: get_color_from_hex("#98F1DD")
                                    padding: [dp(5),dp(2)]
                                    radius: [dp(5)]
                                    md_bg_color: get_color_from_hex("#262C3A")
                                FitImage:
                                    source:root.next_image_source
                                    radius:[10]
                                    fit_mode:"cover"
                                    size_hint:[None,None]
                                    size:[dp(60), dp(60)]


                        Row:
                            adaptive_size:True
                            spacing:dp(10)
                            pos_hint: {"right":1}
    #                        MyMDButton:
    #                            radius: [5]
    #                            theme_bg_color:"Custom"
    #                            MDButtonText:
    #                                text:"Change Current"
    #                                theme_text_color:"Custom"
    #                                text_color: "black" if app.device_theme == "light" else "white"
                            MyMDButton:
                                id: skip_upcoming_wallpaper_button
                                radius: [5]
                                theme_bg_color:"Custom"
                                MDButtonText:
                                    text:"Skip Next"
                                    theme_text_color:"Custom"
                                    text_color: "black" if app.device_theme == "light" else "white"
                        Row:
                            adaptive_size:True
                            spacing:dp(10)
                            pos_hint: {"right":1}
                            MDIconButton:
                                id: pause_home_screen_widget_loop_button
                                icon: "pause"
                                pos_hint:{"right":1}
                                text_color: "black" if app.device_theme == "light" else "white"
                                on_release: root.toggle_home_screen_widget_loop(self)
                            MyMDButton:
                                theme_bg_color:"Custom"
                                md_bg_color: TEXT_COLOR_PRIMARY_DARK if app.device_theme == "light" else BUTTON_BG_DARK
                                radius: [5]
                                on_release:add_home_screen_widget()
                                MDButtonIcon:
                                    icon:"plus"
                                    text_color: "black" if app.device_theme == "light" else "white"
                                MDButtonText:
                                    text:"Add to Home Screen"
                                    theme_text_color:"Custom"
                                    text_color: "black" if app.device_theme == "light" else "white"
                SettingsSection:
                    title_text: "Carousel"
                    ToggleSliderRow:
                        title_text: "Use On-wake"
                        sub_title_text: 'Get a new wallpaper each time you "turn on screen".'
                    ToggleSliderRow:
                        title_text:"Use interval"
                        sub_title_text:f'Get a new wallpaper every "{root.displayed_interval_value}".'
                    CarouselTools:

                SettingsSection:
                    title_text: "Uninstalling?"
                    MyMDButton:
                        theme_bg_color:"Custom"
                        md_bg_color: TEXT_COLOR_PRIMARY_DARK if app.device_theme == "light" else BUTTON_BG_DARK
                        radius: [5]
                        pos_hint: {"center_x": 0.5}
                        on_release: app.sm.get_screen("settings").export_waller_folder()
                        MDButtonIcon:
                            id: btn_icon
                            icon:"export-variant"
                            text_color: "black" if app.device_theme == "light" else "white"
                        MDButtonText:
                            id: btn_text
                            text: "export wallpapers"
                            theme_text_color:"Custom"
                            text_color: "black" if app.device_theme == "light" else "white"
                Button:
                    text: f"v{VERSION}"
                    pos_hint: {"right":1}
                    background_color:[0,0,0,0]
                    size_hint: [None, None]
                    size: [self.texture_size[0], dp(50)]
                    font_name: "RobotoMono"
                    font_size: sp(14)
                    padding:[dp(10),dp(10)]
                    on_release: root.open_logs_screen()
                    color: "black" if app.device_theme == "light" else "grey"
