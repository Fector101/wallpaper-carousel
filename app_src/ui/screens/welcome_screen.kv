
<MyLabel>:
    theme_font_name:"Custom"
    theme_font_size:"Custom"
    theme_bg_color:"Custom"
    theme_text_color:"Custom"
    font_name: "RobotoMono"
    size_hint: [None,None]
    size: self.texture_size

<Circle@MDBoxLayout>:
    size_hint: None, None
    size: 40, 40
    radius: 50
    md_bg_color: 116/255, 155/255, 215/255, 1
    pos_hint: {"top": 1}

#<Paint@BoxLayout>
#    canvas:
#        Color:
#            rgba: (1, 0, 0, .5)
#        Rectangle:
#            pos: self.pos
#            size: self.size
<NotificationRequestLayout>:
    rows: 4
    padding: dp(25), dp(60), dp(25), dp(20)
    spacing: dp(50)
    md_bg_color: app.theme_colors.BG
    pos_hint: {"top":1}

    # Header
    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(10)
        size_hint: [None,None]
        size: self.minimum_size
        MyLabel:
            text: "Turn On\nNotifications?"
            bold: True
            color: app.theme_colors.TEXT_PRIMARY
            theme_font_size:"Custom"
            font_size: sp(36)
            adaptive_size: True
            halign:"left"

            size_hint: [None,None]
            size: self.texture_size


        MDLabel:
            text:"To keep Carousel running in the\nbackground, Android requires a\nforeground notification"
            color: app.theme_colors.TEXT_SECONDARY
            theme_font_size:"Custom"
            font_size: sp(14)
            theme_font_name:"Custom"
            font_name: "RobotoMono"
            adaptive_size: True
            halign:"left"
            size_hint: [None,None]
            size: self.texture_size
    # Middle Section
    MDBoxLayout:
        orientation: "vertical"
        size_hint: 1, None
        height: self.minimum_height
        spacing: dp(10)
        padding: dp(10)
        md_bg_color: app.theme_colors.BG_NOTIFICATION_AREA

        radius: dp(8)

        RotatedLayout:
            pos_hint: {"center_x": .9}


            Image:
                source: "assets/icons/bell.png"
                size_hint: None, None
                size: dp(100), dp(100)
                pos_hint: {"center_x": .5, "center_y": .5}

        MDBoxLayout:
            adaptive_height:True
            spacing: dp(5)
            MDIcon:
                icon: "checkbox-blank-circle"
#                theme_text_color: "Hint"
                theme_text_color:"Custom"
                text_color: app.theme_colors.TEXT_PRIMARY
                adaptive_size: True
                pos_hint:{'center_y': .5}
                theme_font_size:"Custom"
                font_size: sp(6)

            MyLabel:
                text: "Additional Features"
                bold: True
                color: app.theme_colors.TEXT_PRIMARY
                adaptive_size: True
                size_hint: [None,None]
                size: self.texture_size
        MDBoxLayout:
            adaptive_height:True
            MDLabel:
                text: "See what’s coming and skip images without opening app"
#                theme_text_color: "Hint"
                size_hint_x:1
                adaptive_height:1
                theme_font_size:"Custom"
                font_size: sp(14)
                theme_font_name:"Custom"
                font_name: "RobotoMono"
                text_color: app.theme_colors.TEXT_SECONDARY


        # Notification Card
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(10)
            padding: dp(10)
            radius: dp(20),
            md_bg_color: app.theme_colors.BG_NOTIFICATION_CARD

            Circle:

            MDBoxLayout:
                orientation: "vertical"
                adaptive_size: True
                spacing: dp(10)
                pos_hint:{'top': 1}
                size_hint_x:1

                MDBoxLayout:
                    adaptive_size: True
                    spacing: dp(5)

                    MyLabel:
                        text: "Waller"
                        font_size: sp(14)
                        adaptive_size: True
                        color: app.theme_colors.TEXT_SECONDARY

                    MDIcon:
                        icon: "checkbox-blank-circle"
#                        theme_text_color:"Hint"
                        theme_text_color:"Custom"
                        color: app.theme_colors.TEXT_SECONDARY
                        adaptive_size: True
                        pos_hint:{'center_y': .5}
                        theme_font_size:"Custom"
                        font_size: sp(6)

                    MyLabel:
                        text: "20m"
                        font_size: sp(14)
                        adaptive_size: True
                        color: app.theme_colors.TEXT_SECONDARY
#                        theme_text_color:"Hint"

                MyLabel:
                    text: "Next in 1:26"
                    font_size: sp(14)
                    adaptive_size: True
#                    theme_text_color:"Primary"
                    color: app.theme_colors.TEXT_PRIMARY

                MDBoxLayout:
                    md_bg_color: app.theme_colors.BG_SKIP_PILL
                    adaptive_size:1
                    padding: dp(6), dp(4)
                    radius: dp(4)
                    MyLabel:
                        text: "Skip"
                        font_size: sp(14)
                        adaptive_size: True
#                        theme_text_color:"Secondary"
                        color: app.theme_colors.TEXT_ACCENT

            MDBoxLayout:
                adaptive_size: True
                pos_hint: {"top": .95}
                radius: dp(5),
                md_bg_color: 161/255, 163/255, 172/255, 1

                FitImage:
                    source: "assets/icons/mountain.png"
                    size_hint: None, None
                    size: dp(60), dp(60)
                    radius: dp(5)

            MDBoxLayout:
                adaptive_size: True
                radius: dp(50)
                md_bg_color: app.theme_colors.BG_CHEVRON
                pos_hint: {"top": 1, "right": 1}

                MDIcon:
                    icon: "chevron-up"
                    text_color: app.theme_colors.TEXT_SKIP

    # Bottom Buttons
    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(10)

        MyRoundButton:
            text: "Enable notifications"
            bg_color: app.theme_colors.BUTTON_PRIMARY
            back_layer_bg_color: app.theme_colors.BUTTON_WHITE_LAYER
            size_hint_y: None
            height: dp(48)
            font_size: sp(16)
            on_release: root.enable_notifications()

        MyRoundButton:
            text: "Skip Feature"
            bg_color: app.theme_colors.BUTTON_DANGER
            back_layer_bg_color: app.theme_colors.BUTTON_WHITE_LAYER
            color: 0, 0, 0, 1
            size_hint: None, None
            size: sp(248), dp(44)
            font_size: dp(14)
            pos_hint: {"center_x": .5}
            on_release: root.skip_feature()


